<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="22dp"
    android:background="@drawable/bg_dialog_logout">

    <TextView
        android:id="@+id/txtIconeLogoutDialog"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_dialog_cancelar"
        android:gravity="center"
        android:text="◌"
        android:textColor="@color/moneva_danger"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtTituloLogoutDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Deseja sair da sua conta?"
        android:textColor="@color/moneva_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtMensagemLogoutDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Você precisará fazer login novamente para acessar seus dados."
        android:textColor="@color/moneva_text_secondary"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelarLogoutDialog"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:background="@drawable/bg_dialog_cancelar"
            android:minWidth="110dp"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="@color/moneva_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnConfirmarLogoutDialog"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_dialog_confirmar"
            android:minWidth="120dp"
            android:text="Confirmar"
            android:textAllCaps="false"
            android:textColor="@color/moneva_danger"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>