<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moneva_bg">

    <ScrollView
        android:id="@+id/scrollGestor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="70dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CABEÇALHO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTituloTransacoes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moneva"
                        android:textColor="@color/moneva_green"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtSubtituloTransacoes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Todas as contas"
                        android:textColor="@color/moneva_text_secondary"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnMesAnterior"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_profile_close"
                        android:gravity="center"
                        android:text="‹"
                        android:contentDescription="Mês Anterior"
                        android:textColor="@color/moneva_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtMesAtualTransacoes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="Abril 2026"
                        android:textColor="@color/moneva_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnMesProximo"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_profile_close"
                        android:gravity="center"
                        android:text="›"
                        android:contentDescription="Próximo Mês"
                        android:textColor="@color/moneva_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- FERRAMENTAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:baselineAligned="false"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnFiltro"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_profile_close"
                    android:gravity="center"
                    android:text="⏷"
                    android:contentDescription="Filtro"
                    android:textColor="@color/moneva_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnBusca"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_profile_close"
                    android:gravity="center"
                    android:text="⌕"
                    android:contentDescription="Buscar"
                    android:textColor="@color/moneva_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnLixeira"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_profile_close"
                    android:gravity="center"
                    android:text="🗑"
                    android:contentDescription="Lixeira"
                    android:textColor="@color/moneva_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- CHIP DE BUSCA/FILTRO ATIVO -->
            <LinearLayout
                android:id="@+id/layoutBuscaAtiva"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_transacao_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtBuscaAtiva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filtro ativo"
                    android:textColor="@color/moneva_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnLimparBusca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Limpar busca"
                    android:textColor="@color/moneva_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- RESUMO -->
            <LinearLayout
                android:id="@+id/cardResumoGestor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_home_card"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="240dp"
                    android:layout_height="240dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChartGestor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entradas"
                            android:textColor="@color/moneva_green"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtEntradasValor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 0,00"
                            android:textColor="@color/moneva_green"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Saídas"
                            android:textColor="@color/moneva_danger"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtSaidasValor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 0,00"
                            android:textColor="@color/moneva_danger"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>

                <!-- BOTÕES FIXOS -->
                <LinearLayout
                    android:id="@+id/layoutAcoesFixas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnNovaDespesaFixo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_transacao_despesa"
                        android:gravity="center"
                        android:text="−"
                        android:contentDescription="Nova Despesa"
                        android:textColor="@color/moneva_text_primary"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_transacao_chip"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Saldo "
                            android:textColor="@color/moneva_text_primary"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/txtSaldoValor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 0,00"
                            android:textColor="@color/moneva_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnNovaReceitaFixo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_transacao_receita"
                        android:gravity="center"
                        android:text="+"
                        android:contentDescription="Nova Receita"
                        android:textColor="@color/moneva_text_primary"
                        android:textSize="34sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- LISTA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Movimentações do mês"
                android:textColor="@color/moneva_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/containerCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTÕES FLUTUANTES -->
    <LinearLayout
        android:id="@+id/layoutAcoesFlutuantes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="85dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnNovaReceitaFlutuante"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transacao_receita"
            android:gravity="center"
            android:text="+"
            android:contentDescription="Nova Receita"
            android:textColor="@color/moneva_text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNovaDespesaFlutuante"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_transacao_despesa"
            android:gravity="center"
            android:text="−"
            android:contentDescription="Nova Despesa"
            android:textColor="@color/moneva_text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />
    </LinearLayout>


    <!-- BARRA INFERIOR FIXA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav_bar"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:importantForAccessibility="no"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home"
                android:textColor="@color/moneva_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navGestor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_bottom_nav_item_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:importantForAccessibility="no"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Gestor"
                android:textColor="@color/moneva_green"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTrilha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠"
                android:importantForAccessibility="no"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Trilha"
                android:textColor="@color/moneva_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰"
                android:importantForAccessibility="no"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Menu"
                android:textColor="@color/moneva_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>