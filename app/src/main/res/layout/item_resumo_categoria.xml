<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_home_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtIconeCategoriaItem"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="🏠"
        android:textSize="24sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtTituloCategoriaItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moradia"
            android:textColor="@color/moneva_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtTipoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Despesa"
                android:textColor="@color/moneva_text_secondary"
                android:textSize="14sp" />

            <View
                android:id="@+id/viewEditadoDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_status_dot_edited"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtDescricaoCategoriaItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Débito • internet e água"
                android:textColor="@color/moneva_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtValorCategoriaItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="- R$ 350,00"
            android:textColor="@color/moneva_danger"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnEditarItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar"
                android:textColor="@color/moneva_green"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnExcluirItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="🗑"
                android:textColor="@color/moneva_text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>