<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moneva_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- BARRA DE PROGRESSO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnFecharAtividade03"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/moneva_text_secondary"
            android:textSize="24sp"
            android:padding="8dp" />

        <ProgressBar
            android:id="@+id/progressAtividade03"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="@color/moneva_progress_bg"
            android:progressTint="@color/moneva_green" />
    </LinearLayout>

    <!-- ÁREA DA PERGUNTA -->
    <TextView
        android:id="@+id/txtPerguntaAtividade03"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="O que acontece com o seu dinheiro quando a INFLAÇÃO aumenta?"
        android:textColor="@color/moneva_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtIconeCentral03"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:text="💸"
        android:textSize="80sp" />

    <!-- OPÇÕES EM LISTA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/opcao3_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="18dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textColor="@color/moneva_green"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtOpcao3_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Seu dinheiro passa a valer MAIS."
                android:textColor="@color/moneva_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/opcao3_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="18dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B"
                android:textColor="@color/moneva_green"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtOpcao3_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="O poder de compra DIMINUI."
                android:textColor="@color/moneva_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/opcao3_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="18dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C"
                android:textColor="@color/moneva_green"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/txtOpcao3_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Os preços dos produtos CAEM."
                android:textColor="@color/moneva_text_primary" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnVerificarAtividade03"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_login_button"
        android:text="VERIFICAR"
        android:textColor="@color/moneva_button_text"
        android:textStyle="bold"
        android:enabled="false"
        android:alpha="0.5"/>

</LinearLayout>
