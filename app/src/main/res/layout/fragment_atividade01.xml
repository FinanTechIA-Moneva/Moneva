<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moneva_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- CABEÇALHO COM PROGRESSO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnFecharAtividade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/moneva_text_secondary"
            android:textSize="24sp"
            android:padding="8dp" />

        <ProgressBar
            android:id="@+id/progressAtividade"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="20"
            android:progressBackgroundTint="@color/moneva_progress_bg"
            android:progressTint="@color/moneva_green" />
    </LinearLayout>

    <!-- PERGUNTA -->
    <TextView
        android:id="@+id/txtPergunta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="O que é uma Reserva de Emergência?"
        android:textColor="@color/moneva_text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- OPÇÕES -->
    <LinearLayout
        android:id="@+id/containerOpcoes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- OPÇÃO 1 -->
        <LinearLayout
            android:id="@+id/opcao1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/moneva_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOpcao1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Dinheiro guardado para viagens e lazer."
                android:textColor="@color/moneva_text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- OPÇÃO 2 -->
        <LinearLayout
            android:id="@+id/opcao2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="@color/moneva_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOpcao2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Um valor para cobrir gastos imprevistos e urgentes."
                android:textColor="@color/moneva_text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- OPÇÃO 3 -->
        <LinearLayout
            android:id="@+id/opcao3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="@color/moneva_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtOpcao3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="O limite total do seu cartão de crédito."
                android:textColor="@color/moneva_text_primary"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- BOTÃO VERIFICAR -->
    <Button
        android:id="@+id/btnVerificarAtividade"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_login_button"
        android:text="VERIFICAR"
        android:textAllCaps="true"
        android:textColor="@color/moneva_button_text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        android:alpha="0.5"/>

</LinearLayout>
