<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moneva_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="@color/moneva_green"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Acesse opções importantes do seu app"
            android:textColor="@color/moneva_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_home_card"
            android:orientation="vertical"
            android:padding="18dp">

            <Button
                android:id="@+id/btnIrPerfil"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_login_button"
                android:text="Ir para Perfil"
                android:textAllCaps="false"
                android:textColor="@color/moneva_button_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVoltarHome"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_highlight"
                android:text="Voltar para Home"
                android:textAllCaps="false"
                android:textColor="@color/moneva_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSairContaMenu"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_logout_button"
                android:text="Sair da conta"
                android:textAllCaps="false"
                android:textColor="@color/moneva_danger"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>