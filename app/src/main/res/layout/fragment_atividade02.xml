<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/moneva_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- CABEÇALHO COM PROGRESSO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnFecharAtividade02"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/moneva_text_secondary"
            android:textSize="24sp"
            android:padding="8dp" />

        <ProgressBar
            android:id="@+id/progressAtividade02"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="@color/moneva_progress_bg"
            android:progressTint="@color/moneva_green" />
    </LinearLayout>

    <!-- PERGUNTA -->
    <TextView
        android:id="@+id/txtPerguntaAtividade02"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Qual destes é considerado um GASTO ESSENCIAL?"
        android:textColor="@color/moneva_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- OPÇÕES COM IMAGENS/EMOJIS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- OPÇÃO 1 -->
        <LinearLayout
            android:id="@+id/opcao2_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtIconeOpcao2_1"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="🎬"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/txtOpcao2_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Assinatura de Streaming"
                android:textColor="@color/moneva_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- OPÇÃO 2 -->
        <LinearLayout
            android:id="@+id/opcao2_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtIconeOpcao2_2"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="🏠"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/txtOpcao2_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Aluguel / Moradia"
                android:textColor="@color/moneva_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- OPÇÃO 3 -->
        <LinearLayout
            android:id="@+id/opcao2_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_home_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtIconeOpcao2_3"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:text="🍔"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/txtOpcao2_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Jantar fora no final de semana"
                android:textColor="@color/moneva_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- BOTÃO VERIFICAR -->
    <Button
        android:id="@+id/btnVerificarAtividade02"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_login_button"
        android:text="VERIFICAR"
        android:textAllCaps="true"
        android:textColor="@color/moneva_button_text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        android:alpha="0.5"/>

</LinearLayout>
